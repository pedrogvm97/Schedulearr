<?xml version="1.0"?>
<Container version="2">
  <Name>Arr-Scheduler</Name>
  <Repository>ghcr.io/pedrogvm97/arr-scheduler</Repository>
  <Registry>https://ghcr.io/</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/pedrogvm97/arr-scheduler/issues</Support>
  <Project>https://github.com/pedrogvm97/arr-scheduler</Project>
  <Overview>A localized Next.js web application to act as an intelligent scheduler and orchestrator for Radarr, Sonarr, and Prowlarr without external internet access.</Overview>
  <Category>MediaApp:Video MediaApp:Music Other:</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/nextjs/desktop/main/assets/nextjs-icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Arr-Scheduler is a tool designed to intelligently trigger searches for missing media in Radarr and Sonarr, monitoring Prowlarr indexer health to avoid ban limits.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>3000</HostPort>
        <ContainerPort>3000</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/arr-scheduler/data</HostDir>
      <ContainerDir>/app/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment/>
  <Labels/>
  <Config Name="WebUI" Target="3000" Default="3000" Mode="tcp" Description="Web interface port" Type="Port" Display="always" Required="true" Mask="false">3000</Config>
  <Config Name="AppData Config Path" Target="/app/data" Default="/mnt/user/appdata/arr-scheduler/data" Mode="rw" Description="Path to store SQLite database configuration." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/arr-scheduler/data</Config>
</Container>
